    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u0414\u0435\u0440\u0435\u0432\u043E \u043D\u0430\u0432\u044B\u043A\u043E\u0432\n\n\u0423\u0440\u043E\u0432\u0435\u043D\u044C
    1 -> +HP\n\u0423\u0440\u043E\u0432\u0435\u043D\u044C 2 -> +\u0428\u0430\u043D\u0441
    \u0440\u0435\u0434\u043A\u043E\u0441\u0442\u0438\n\u0423\u0440\u043E\u0432\u0435\u043D\u044C
    3 -> +\u0421\u0442\u0430\u0440\u0442\u043E\u0432\u044B\u0439 \u0443\u0440\u043E\u0432\u0435\u043D\u044C\n\u0423\u0440\u043E\u0432\u0435\u043D\u044C
    4 -> +\u041F\u0443\u043B \u043D\u0430\u0432\u044B\u043A\u043E\u0432\n\n\u041F\u043E\u043A\u0430
    \u044D\u0442\u043E \u0432\u0438\u0437\u0443\u0430\u043B\u044C\u043D\u0430\u044F
    \u0437\u0430\u0433\u043E\u0442\u043E\u0432\u043A\u0430 \u0434\u043B\u044F \u0431\u0443\u0434\u0443\u0449\u0435\u0439
    \u043C\u0435\u0442\u0430-\u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u0438."
